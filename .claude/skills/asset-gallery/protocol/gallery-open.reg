Windows Registry Editor Version 5.00

; gallery-open: custom protocol — lets gallery.html "Edit copy" / "Open folder"
; buttons launch a text editor / File Explorer instead of rendering in-browser.
; User-level only (HKCU) — no admin rights needed. Remove by deleting the
; HKEY_CURRENT_USER\Software\Classes\gallery-open key.

[HKEY_CURRENT_USER\Software\Classes\gallery-open]
@="URL:gallery-open protocol"
"URL Protocol"=""

[HKEY_CURRENT_USER\Software\Classes\gallery-open\shell]

[HKEY_CURRENT_USER\Software\Classes\gallery-open\shell\open]

[HKEY_CURRENT_USER\Software\Classes\gallery-open\shell\open\command]
@="powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File \"C:\\Users\\operator\\OneDrive\\Claude\\Marketing AI System\\.claude\\skills\\asset-gallery\\protocol\\gallery-open.ps1\" \"%1\""
